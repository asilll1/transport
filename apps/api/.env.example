PORT=8080
TELEGRAM_BOT_TOKEN=
MINI_APP_URL=https://YOUR_PROJECT_ID.web.app
LIBRETRANSLATE_URL=https://libretranslate.com
# Optional if your LibreTranslate instance requires it
# LIBRETRANSLATE_API_KEY=
# Full JSON on one line, or paste multiline in Render (must be real JSON: "key": "value")
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Alternative if the dashboard mangles JSON: base64 -w0 your-key.json → one line
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=
# Random secret; cron POST /internal/cron with Authorization: Bearer <this>
CRON_SECRET=
# Comma-separated origins, or * (default in code)
# CORS_ORIGINS=https://YOUR_PROJECT_ID.web.app,https://web.telegram.org
